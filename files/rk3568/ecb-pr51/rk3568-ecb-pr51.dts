    vepu@fdee0000 {
        power-domains = <0x21 0xA>;
        iommus = <0x6F>;
        clock-names = "aclk_vcodec", "hclk_vcodec";
        resets = <0x1F 0x12E 0x1F 0x12F>;
        interrupts = <0x0 0x40 0x4>;
        clocks = <0x1F 0xFD 0x1F 0xFE>;
        rockchip,srv = <0x6C>;
        rockchip,taskqueue-node = <0x2>;
        rockchip,disable-auto-freq;
        compatible = "rockchip,vpu-encoder-v2";
        rockchip,resetgroup-node = <0x2>;
        status = "okay";
        reg = <0x0 0xFDEE0000 0x0 0x400>;
        phandle = <0x18F>;
        reset-names = "video_a", "video_h";
    };
    sfc@fe300000 {
        clock-names = "clk_sfc", "hclk_sfc";
        assigned-clocks = <0x1F 0x78>;
        assigned-clock-rates = <0x5F5E100>;
        interrupts = <0x0 0x65 0x4>;
        clocks = <0x1F 0x78 0x1F 0x76>;
        compatible = "rockchip,sfc";
        status = "okay";
        reg = <0x0 0xFE300000 0x0 0x4000>;
        phandle = <0x1B8>;
    };
    pwm@fe6f0030 {
        pinctrl-names = "active";
        pinctrl-0 = <0x112>;
        clock-names = "pwm", "pclk";
        interrupts = <0x0 0x54 0x4 0x0 0x58 0x4>;
        clocks = <0x1F 0x15D 0x1F 0x15C>;
        #pwm-cells = <0x3>;
        compatible = "rockchip,rk3568-pwm", "rockchip,rk3328-pwm";
        status = "disabled";
        reg = <0x0 0xFE6F0030 0x0 0x10>;
        phandle = <0x1E2>;
    };
    nocp-vo@fe103000 {
        compatible = "rockchip,rk3568-nocp";
        reg = <0x0 0xFE103000 0x0 0x100>;
        phandle = <0x1AF>;
    };
    sata@fc000000 {
        power-domains = <0x21 0xF>;
        phy-names = "sata-phy";
        clock-names = "sata", "pmalive", "rxoob";
        interrupts = <0x0 0x5E 0x4>;
        clocks = <0x1F 0x96 0x1F 0x97 0x1F 0x98>;
        compatible = "snps,dwc-ahci";
        status = "disabled";
        interrupt-names = "hostc";
        phys = <0x20 0x1>;
        reg = <0x0 0xFC000000 0x0 0x1000>;
        phandle = <0x167>;
        ports-implemented = <0x1>;
    };
    phy@fe820000 {
        rockchip,pipe-grf = <0x11A>;
        clock-names = "refclk", "apbclk", "pipe_clk";
        assigned-clocks = <0x32 0x1F>;
        assigned-clock-rates = <0x5F5E100>;
        resets = <0x1F 0x1C4 0x1F 0x1C5>;
        clocks = <0x32 0x1F 0x1F 0x17C 0x1F 0x7F>;
        #phy-cells = <0x1>;
        compatible = "rockchip,rk3568-naneng-combphy";
        status = "okay";
        rockchip,pipe-phy-grf = <0x11B>;
        reg = <0x0 0xFE820000 0x0 0x100>;
        phandle = <0x20>;
        reset-names = "combphy-apb", "combphy";
    };
    serial@fe6d0000 {
        reg-io-width = <0x4>;
        pinctrl-names = "default";
        pinctrl-0 = <0x10A>;
        clock-names = "baudclk", "apb_pclk";
        interrupts = <0x0 0x7D 0x4>;
        clocks = <0x1F 0x13F 0x1F 0x13C>;
        compatible = "rockchip,rk3568-uart", "snps,dw-apb-uart";
        status = "disabled";
        reg = <0x0 0xFE6D0000 0x0 0x100>;
        phandle = <0x1DC>;
        dmas = <0x41 0x12 0x41 0x13>;
        reg-shift = <0x2>;
    };
    reserved-memory {
        #address-cells = <0x2>;
        #size-cells = <0x2>;
        ranges;
        phandle = <0x155>;
        drm-logo@00000000 {
            compatible = "rockchip,drm-logo";
            reg = <0x0 0xEDF00000 0x0 0xD39D8>;
            phandle = <0x10>;
        };
        ramoops@110000 {
            record-size = <0x20000>;
            pmsg-size = <0x50000>;
            compatible = "ramoops";
            console-size = <0x80000>;
            reg = <0x0 0x110000 0x0 0xF0000>;
            phandle = <0x156>;
